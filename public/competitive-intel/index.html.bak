    <script>
        // Filter by vertical
        function filterByVertical(vertical) {
            // Update button states
            document.querySelectorAll('.vertical-filter button').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            // Update battlecards visibility
            const battlecards = document.querySelectorAll('.battlecard');
            battlecards.forEach(card => {
                const verticals = card.getAttribute('data-verticals').split(',');
                if (vertical === 'all' || verticals.includes(vertical)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });

            // Update vertical panels
            document.querySelectorAll('.vertical-panel').forEach(panel => {
                panel.classList.remove('active');
            });
            if (vertical !== 'all') {
                const activePanel = document.querySelector(`[data-vertical="${vertical}"]`);
                if (activePanel) {
                    activePanel.classList.add('active');
                }
            }
        }

        // Search all intel sections
        function searchBattlecards() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            // 1. Filter Battlecards
            document.querySelectorAll('.battlecard').forEach(card => {
                const text = card.textContent.toLowerCase();
                card.style.display = (searchTerm === '' || text.includes(searchTerm)) ? 'block' : 'none';
            });
            
            // 2. Filter Table Rows across all intelligence sections
            document.querySelectorAll('.comparison-matrix tbody tr, .vertical-panel tbody tr, .boutique-section tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = (searchTerm === '' || text.includes(searchTerm)) ? '' : 'none';
            });
        }

        // Copy battlecard to clipboard
        function copyBattlecard(competitor) {
            const card = document.querySelector(`[data-competitor="${competitor}"]`);
            const text = card.innerText;
            navigator.clipboard.writeText(text).then(() => {
                const btn = card.querySelector('.copy-button');
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = 'Copy', 2000);
            });
        }

        // Download battlecard as .txt file
        function downloadBattlecard(competitor) {
            const card = document.querySelector(`[data-competitor="${competitor}"]`);
            const text = card.innerText;
            const blob = new Blob([text], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `TP_Battlecard_${competitor.charAt(0).toUpperCase() + competitor.slice(1)}.txt`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        // Reset generator to defaults
        function resetGenerator(type) {
            if (type === 'displacement') {
                document.getElementById('competitorSelect').selectedIndex = 0;
                document.getElementById('channelSelect').selectedIndex = 0;
                document.getElementById('personaSelect').selectedIndex = 0;
                document.getElementById('displacementAccountName').value = '';
                document.getElementById('displacementOutput').textContent = 'Select options to generate offer...';
                document.getElementById('displacementOutput').innerHTML = 'Select options to generate offer...';
            } else {
                document.getElementById('triggerSelect').selectedIndex = 0;
                document.getElementById('verticalSelect').selectedIndex = 0;
                document.getElementById('conversationAccountName').value = '';
                document.getElementById('conversationOutput').textContent = 'Select a scenario to generate talking points...';
                document.getElementById('conversationOutput').innerHTML = 'Select a scenario to generate talking points...';
            }
        }

        // Download generator output as .txt
        function downloadGenerator(type) {
            let output, filename;
            if (type === 'displacement') {
                output = document.getElementById('displacementOutput');
                const competitor = document.getElementById('competitorSelect').value || 'general';
                const channel = document.getElementById('channelSelect').value || 'multi';
                filename = `TP_Displacement_${competitor}_${channel}.txt`;
            } else {
                output = document.getElementById('conversationOutput');
                const trigger = document.getElementById('triggerSelect').value || 'general';
                const vertical = document.getElementById('verticalSelect').value || 'all';
                filename = `TP_ConversationAngle_${trigger}_${vertical}.txt`;
            }
            const text = output.innerText;
            if (!text || text.includes('Select options') || text.includes('Select a scenario')) {
                alert('Generate content first before downloading.');
                return;
            }
            const blob = new Blob([text], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        // Generate displacement offer
        function generateDisplacementOffer() {
            const competitor = document.getElementById('competitorSelect').value;
            const channel = document.getElementById('channelSelect').value;
            const persona = document.getElementById('personaSelect').value;
            const output = document.getElementById('displacementOutput');

            if (!competitor || !channel || !persona) {
                output.textContent = 'Select all options to generate offer...';
                return;
            }

            const offers = {
                email: {
                    cxo: `Subject: CX Outcomes You're Missing—Teleperformance Case Study

Hi [Name],

I was reviewing ${competitor}'s recent earnings, and something stood out: their CX satisfaction scores are flat despite 20% headcount growth. That's expensive.

Teleperformance just delivered a similar client with 35% higher CSAT, 45% faster resolution times, and 25% lower cost. No magic—just CX-first architecture that ${competitor} hasn't caught up to.

If you're curious how we stack up for [your use case], let's spend 15 minutes. No pitch, just outcomes.

Best,
[Your Name]`,
                    procurement: `Subject: Cost Reduction Opportunity—${competitor} Overlap Analysis

