        // AI Enhancement via Gemini
        async function enhanceWithAI(type) {
            let btn, output, accountName, params;

            if (type === 'displacement') {
                btn = document.getElementById('displacementAiBtn');
                output = document.getElementById('displacementOutput');
                accountName = document.getElementById('displacementAccountName').value;
                const competitor = document.getElementById('competitorSelect').value;
                const channel = document.getElementById('channelSelect').value;
                const persona = document.getElementById('personaSelect').value;

                if (!competitor || !channel || !persona) {
                    alert('Select competitor, channel, and persona first.');
                    return;
                }
                params = { type: 'displacement', competitor, channel, persona, accountName: accountName || 'the target account', staticTemplate: output.textContent };
            } else {
                btn = document.getElementById('conversationAiBtn');
                output = document.getElementById('conversationOutput');
                accountName = document.getElementById('conversationAccountName').value;
                const trigger = document.getElementById('triggerSelect').value;
                const vertical = document.getElementById('verticalSelect').value;

                if (!trigger) {
                    alert('Select a trigger scenario first.');
                    return;
                }
                params = { type: 'conversation', trigger, vertical: vertical || 'all', accountName: accountName || 'the target account', staticTemplate: output.textContent };
            }

            // Show loading
            btn.disabled = true;
            btn.textContent = 'Generating...';
            output.classList.add('ai-loading');

            try {
                const response = await fetch('/api/battlecard', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(params)
                });

                if (!response.ok) throw new Error('AI generation failed');

                const data = await response.json();
                output.innerHTML = '<span class="ai-badge">AI ENHANCED</span>\n' + data.output.replace(/\n/g, '<br>');
            } catch (error) {
                console.error('AI enhance error:', error);
                output.textContent += '\n\n⚠ AI enhancement unavailable. Static template shown above.';
            } finally {
                btn.disabled = false;
                btn.textContent = 'Generate with AI';
                output.classList.remove('ai-loading');
            }
        }

        // File upload
        function triggerFileUpload() {
            document.getElementById('fileInput').click();
        }

        function handleFileUpload() {
            const files = document.getElementById('fileInput').files;
            alert(`${files.length} file(s) uploaded successfully!`);
        }
    </script>

