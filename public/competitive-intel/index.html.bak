<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Competitive Intel | ABM Suite</title>
    <style>
        :root {
            --slate: #484C6A;
            --slate-dark: #2e3150;
            --pink: #ff0082;
            --white: #ffffff;
            --pastel-slate: #c2c7cd;
            --pastel-violet: #e2dfe8;
            --accenture-blue: #0099ff;
            --cognizant-purple: #7030a0;
            --tcs-blue: #0066cc;
            --ttec-orange: #ff6600;
            --ibm-blue: #0f62fe;
            --atento-green: #00a651;
            --taskus-red: #d32f2f;
            --concentrix-gold: #ffc107;
            --foundever-teal: #00bcd4;
            --alorica-indigo: #3f51b5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Calibri Light', Calibri, 'Segoe UI', Arial, sans-serif;
            background-color: #f5f5f5;
            color: var(--slate-dark);
            line-height: 1.6;
        }

        /* Hero Section */
        .hero {
            background: var(--slate);
            color: var(--white);
            padding: 80px 24px 60px;
            text-align: center;
            border-bottom: 4px solid var(--pink);
        }

        .hero h1 {
            font-size: 48px;
            margin-bottom: 12px;
            font-weight: 600;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 30px;
            opacity: 0.95;
        }

        .hero-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .hero-stat {
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 8px;
            backdrop-filter: blur(10px);
        }

        .hero-stat-number {
            font-size: 28px;
            font-weight: 700;
            color: var(--pink);
        }

        .hero-stat-label {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Vertical Filter Tabs */
        .vertical-filter {
            display: flex;
            gap: 10px;
            margin-top: 30px;
            margin-bottom: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .vertical-filter button {
            padding: 10px 18px;
            border: 2px solid var(--slate);
            background-color: transparent;
            color: var(--slate);
            border-radius: 25px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .vertical-filter button:hover {
            background-color: var(--slate);
            color: var(--white);
        }

        .vertical-filter button.active {
            background-color: var(--pink);
            border-color: var(--pink);
            color: var(--white);
        }

        /* Search Section */
        .search-section {
            margin-bottom: 30px;
            display: flex;
            justify-content: center;
        }

        .search-container {
            width: 100%;
            max-width: 500px;
            position: relative;
        }

        .search-container input {
            width: 100%;
            padding: 14px 20px;
            border: 2px solid var(--pastel-slate);
            border-radius: 8px;
            font-size: 15px;
            transition: border-color 0.3s ease;
        }

        .search-container input:focus {
            outline: none;
            border-color: var(--pink);
            box-shadow: 0 0 0 3px rgba(255, 0, 130, 0.1);
        }

        /* Win Themes Card */
        .win-themes {
            background: var(--white);
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .win-themes h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--slate);
        }

        .win-themes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .win-theme-item {
            background: var(--white);
            padding: 20px;
            border-radius: 8px;
            border: 1px solid var(--pastel-slate);
            border-left: 3px solid var(--pink);
            text-align: left;
            font-size: 13px;
            font-weight: 500;
            color: var(--slate-dark);
        }

        /* Comparison Matrix */
        .comparison-matrix {
            background: var(--white);
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            overflow-x: auto;
        }

        .comparison-matrix h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--slate);
        }

        .comparison-matrix table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .comparison-matrix th {
            background-color: var(--slate);
            color: var(--white);
            padding: 12px;
            text-align: left;
            font-weight: 600;
        }

        .comparison-matrix td {
            padding: 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .comparison-matrix tr:hover {
            background-color: #f9f9f9;
        }

        .competitor-logo {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            color: var(--white);
            font-weight: 700;
            font-size: 11px;
            margin-right: 8px;
        }

        /* Battlecards Section */
        .battlecards-section {
            margin-bottom: 40px;
        }

        .battlecards-section h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--slate);
        }

        .battlecards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
            gap: 20px;
        }

        .battlecard {
            background: var(--white);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            transition: box-shadow 0.3s ease, transform 0.3s ease;
        }

        .battlecard:hover {
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
            transform: translateY(-2px);
        }

        .battlecard-header {
            background: var(--slate);
            color: var(--white);
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 3px solid var(--pink);
        }

        .battlecard-header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .battlecard-logo {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 700;
            font-size: 18px;
        }

        .battlecard-name {
            font-size: 18px;
            font-weight: 600;
        }

        .threat-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .threat-high {
            background-color: #ffebee;
            color: #c62828;
        }

        .threat-severe {
            background-color: #b71c1c;
            color: var(--white);
        }

        .threat-moderate {
            background-color: #fff3e0;
            color: #e65100;
        }

        .threat-low {
            background-color: #e8f5e9;
            color: #2e7d32;
        }

        .battlecard-body {
            padding: 20px;
        }

        .battlecard-tagline {
            font-size: 13px;
            color: var(--pastel-slate);
            margin-bottom: 15px;
            font-style: italic;
        }

        .battlecard-section {
            margin-bottom: 15px;
        }

        .battlecard-section-title {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--slate);
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .strengths-vulnerabilities {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 15px;
        }

        .strength-item, .vulnerability-item {
            padding: 12px;
            border-radius: 6px;
            font-size: 12px;
            border: 1px solid var(--pastel-slate);
            background: var(--white);
        }

        .strength-item {
            border-left: 3px solid var(--pastel-slate);
            color: var(--slate);
        }

        .vulnerability-item {
            border-left: 3px solid var(--pink);
            color: var(--slate-dark);
        }

        .counter-positioning {
            background-color: var(--pastel-violet);
            padding: 12px;
            border-radius: 6px;
            font-size: 12px;
            color: var(--slate-dark);
            margin-bottom: 15px;
        }

        .win-theme-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 15px;
        }

        .win-theme-pill {
            background-color: var(--pink);
            color: var(--white);
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 11px;
            font-weight: 600;
        }

        .talk-tracks {
            background-color: #f5f5f5;
            padding: 12px;
            border-radius: 6px;
            font-size: 12px;
            margin-bottom: 15px;
        }

        .talk-track-pair {
            margin-bottom: 10px;
        }

        .talk-track-pair:last-child {
            margin-bottom: 0;
        }

        .they-say, .you-say {
            margin-bottom: 5px;
            padding: 5px 0;
        }

        .they-say {
            color: var(--pink);
            font-weight: 600;
        }

        .you-say {
            color: var(--slate-dark);
        }

        .battlecard-footer {
            padding: 12px 20px;
            background-color: #f5f5f5;
            border-top: 1px solid #e0e0e0;
            display: flex;
            justify-content: center;
        }

        .copy-button, .download-button {
            background-color: var(--slate);
            color: var(--white);
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }

        .copy-button:hover, .download-button:hover {
            background-color: var(--slate-dark);
        }

        .download-button {
            background-color: var(--pink);
        }

        .download-button:hover {
            background-color: #cc0069;
        }

        .battlecard-footer {
            gap: 8px;
        }

        .generator-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 600;
            transition: all 0.2s;
        }

        .action-btn.reset {
            background: var(--pastel-slate);
            color: var(--slate-dark);
        }

        .action-btn.reset:hover {
            background: #b0b5bc;
        }

        .action-btn.download {
            background: var(--slate);
            color: white;
        }

        .action-btn.download:hover {
            background: var(--slate-dark);
        }

        /* Vertical Panels */
        .verticals-section {
            margin-bottom: 40px;
        }

        .verticals-section h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--slate);
        }

        .vertical-panel {
            background: var(--white);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            display: none;
        }

        .vertical-panel.active {
            display: block;
        }

        .vertical-panel h3 {
            font-size: 18px;
            color: var(--slate);
            margin-bottom: 15px;
        }

        .vertical-panel table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        .vertical-panel th {
            background-color: var(--pastel-violet);
            color: var(--slate-dark);
            padding: 12px;
            text-align: left;
            font-weight: 600;
        }

        .vertical-panel td {
            padding: 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .vertical-panel tr:hover {
            background-color: #f9f9f9;
        }

        /* Generators */
        .generators-section {
            margin-bottom: 40px;
        }

        .generators-section h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--slate);
        }

        .generators-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 20px;
        }

        .generator-panel {
            background: var(--white);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .generator-panel h3 {
            font-size: 18px;
            color: var(--slate);
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--slate);
            margin-bottom: 6px;
        }

        .form-group select, .form-group input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--pastel-slate);
            border-radius: 6px;
            font-size: 13px;
            font-family: inherit;
        }

        .form-group select:focus, .form-group input:focus {
            outline: none;
            border-color: var(--pink);
            box-shadow: 0 0 0 3px rgba(255, 0, 130, 0.1);
        }

        .generate-button {
            width: 100%;
            padding: 12px;
            background-color: var(--pink);
            color: var(--white);
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }

        .generate-button:hover {
            background-color: #e60072;
        }

        .generator-output {
            background-color: #f5f5f5;
            padding: 15px;
            border-radius: 6px;
            margin-top: 15px;
            min-height: 100px;
            font-size: 12px;
            line-height: 1.5;
            white-space: pre-wrap;
            word-wrap: break-word;
        }

        /* Boutique Tracker */
        .boutique-section {
            background: var(--white);
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .boutique-section h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: var(--slate);
        }

        .boutique-section table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            overflow-x: auto;
        }

        .boutique-section th {
            background-color: var(--slate);
            color: var(--white);
            padding: 12px;
            text-align: left;
            font-weight: 600;
        }

        .boutique-section td {
            padding: 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .boutique-section tr:hover {
            background-color: #f9f9f9;
        }

        /* Upload Section */
        .upload-section {
            background: var(--white);
            padding: 40px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .upload-section h2 {
            font-size: 24px;
            color: var(--slate);
            margin-bottom: 20px;
        }

        .upload-area {
            border: 2px dashed var(--pastel-slate);
            padding: 40px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .upload-area:hover {
            border-color: var(--pink);
            background-color: rgba(255, 0, 130, 0.05);
        }

        .upload-area p {
            font-size: 14px;
            color: var(--slate);
            margin-bottom: 10px;
        }

        .upload-button {
            padding: 10px 20px;
            background-color: var(--pink);
            color: var(--white);
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
        }

        .upload-button:hover {
            background-color: #e60072;
        }

        /* Footer */
        footer {
            background: linear-gradient(135deg, var(--slate) 0%, var(--slate-dark) 100%);
            color: var(--white);
            text-align: center;
            padding: 30px;
            font-size: 12px;
            margin-top: 60px;
        }

        /* Utility Classes */
        .hidden {
            display: none !important;
        }

        .text-center {
            text-align: center;
        }

        .ai-enhance-row {
            display: flex;
            gap: 12px;
            align-items: center;
            margin-top: 12px;
        }
        .ai-enhance-row input {
            flex: 1;
            padding: 10px 14px;
            border: 1px solid var(--pastel-slate);
            border-radius: 8px;
            font-size: 0.9rem;
            font-family: inherit;
        }
        .ai-enhance-btn {
            padding: 10px 20px;
            background: linear-gradient(135deg, var(--pink), #cc0069);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            font-size: 0.85rem;
            white-space: nowrap;
            transition: all 0.2s;
        }
        .ai-enhance-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255,0,130,0.3);
        }
        .ai-enhance-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        .ai-badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--pink), #cc0069);
            color: white;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 700;
            margin-left: 8px;
            vertical-align: middle;
        }
        .generator-output.ai-loading {
            position: relative;
            opacity: 0.7;
        }
        .generator-output.ai-loading::after {
            content: 'Generating with AI...';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--slate);
            color: white;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 0.85rem;
            z-index: 10;
        }
    </style>
</head>
<body>
    <!-- Hero Section -->
    <div class="hero">
        <h1>Competitive Intel</h1>
        <p>Strategic battlecards and competitive positioning for ABM targeting</p>
        <div class="hero-stats">
            <div class="hero-stat">
                <div class="hero-stat-number">10</div>
                <div class="hero-stat-label">Key Competitors</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-number">10</div>
                <div class="hero-stat-label">Vertical Markets</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-number">100+</div>
                <div class="hero-stat-label">Win Themes</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-number">Live</div>
                <div class="hero-stat-label">Updated Daily</div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <!-- Vertical Filter -->
        <div class="vertical-filter">
            <button class="active" onclick="filterByVertical('all')">All Competitors</button>
            <button onclick="filterByVertical('healthcare')">Healthcare</button>
            <button onclick="filterByVertical('banking')">Banking/Finance</button>
            <button onclick="filterByVertical('retail')">Retail/E-Commerce</button>
            <button onclick="filterByVertical('technology')">Technology/TaaS</button>
            <button onclick="filterByVertical('government')">Government</button>
            <button onclick="filterByVertical('insurance')">Insurance</button>
        </div>

        <!-- Search -->
        <div class="search-section">
            <div class="search-container">
                <input type="text" id="searchInput" placeholder="Search competitors, keywords, verticals..." onkeyup="searchBattlecards()">
            </div>
        </div>

        <!-- Win Themes -->
        <div class="win-themes">
            <h2>Teleperformance Win Themes</h2>
            <div class="win-themes-grid">
                <div class="win-theme-item">Speed to Results</div>
                <div class="win-theme-item">Pure-Play CX Expertise</div>
                <div class="win-theme-item">AI in Production</div>
                <div class="win-theme-item">Multi-Vertical Breadth</div>
                <div class="win-theme-item">Talent Stability</div>
                <div class="win-theme-item">Operational Excellence</div>
            </div>
        </div>

        <!-- Comparison Matrix -->
        <div class="comparison-matrix">
            <h2>Quick Competitor Comparison</h2>
            <table>
                <thead>
                    <tr>
                        <th>Competitor</th>
                        <th>HQ Region</th>
                        <th>Est. Revenue</th>
                        <th>Key Strength</th>
                        <th>Primary Weakness</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="competitor-logo" style="background-color: var(--accenture-blue);">AC</span>Accenture</td>
                        <td>Dublin, IE</td>
                        <td>$64B+</td>
                        <td>Global scale & tech portfolio</td>
                        <td>High cost structure</td>
                    </tr>
                    <tr>
                        <td><span class="competitor-logo" style="background-color: var(--pink);">TM</span>Tech Mahindra</td>
                        <td>Pune, India</td>
                        <td>$6.5B+</td>
                        <td>Telecom & IT engineering</td>
                        <td>Generic CX positioning</td>
                    </tr>
                    <tr>
                        <td><span class="competitor-logo" style="background-color: var(--cognizant-purple);">CG</span>Cognizant</td>
                        <td>New Jersey, US</td>
                        <td>$19B+</td>
                        <td>BPO + IT hybrid model</td>
                        <td>Legacy infrastructure</td>
                    </tr>
                    <tr>
                        <td><span class="competitor-logo" style="background-color: var(--tcs-blue);">TCS</span>Tata Consulting</td>
                        <td>Mumbai, India</td>
                        <td>$28B+</td>
                        <td>Cost efficiency</td>
                        <td>Limited vertical specialization</td>
                    </tr>
                    <tr>
                        <td><span class="competitor-logo" style="background-color: var(--ttec-orange);">TTEC</span>TTEC Holdings</td>
                        <td>Denver, US</td>
                        <td>$2.8B+</td>
                        <td>Pure-play CX focus</td>
                        <td>Smaller global footprint</td>
                    </tr>
                    <tr>
                        <td><span class="competitor-logo" style="background-color: var(--ibm-blue);">IBM</span>IBM Services</td>
                        <td>Armonk, US</td>
